# Copy to .env and set ONE key to run the agent's decide step on a real LLM.
# Leave both unset to run in deterministic STUB mode (still fully functional).
#
# Provider precedence: Anthropic is used if set, otherwise Gemini, otherwise the stub.

# --- Option A: Google Gemini -------------------------------------------------
GEMINI_API_KEY=
# Optional model override (default below is fast + free-tier friendly):
GEMINI_MODEL=gemini-2.5-flash

# --- Option B: Anthropic Claude ----------------------------------------------
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
